<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 搜索框 -->
    <LinearLayout
        android:id="@+id/searchContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#4A148C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/editSearch"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="@string/hint_search"
            android:textColorHint="#BBBBBB"
            android:textColor="#FFFFFF"
            android:background="@drawable/search_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="搜索"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B1FA2" />
    </LinearLayout>

    <!-- 搜索结果列表 -->
    <ListView
        android:id="@+id/searchResults"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/searchContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 地图 -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/searchContainer"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 底部面板 -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 坐标显示 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/textLat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/current_lat"
                android:textSize="13sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/textLon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/current_lon"
                android:textSize="13sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- 地址显示 -->
        <TextView
            android:id="@+id/textAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/current_address"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- 设置区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="精度:"
                android:textSize="12sp"
                android:textColor="#666" />

            <EditText
                android:id="@+id/editAccuracy"
                android:layout_width="60dp"
                android:layout_height="36dp"
                android:inputType="number"
                android:text="15"
                android:textSize="13sp"
                android:gravity="center"
                android:background="@drawable/search_bg"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="海拔:"
                android:textSize="12sp"
                android:textColor="#666" />

            <EditText
                android:id="@+id/editAltitude"
                android:layout_width="60dp"
                android:layout_height="36dp"
                android:inputType="number"
                android:text="50"
                android:textSize="13sp"
                android:gravity="center"
                android:background="@drawable/search_bg"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="偏移:"
                android:textSize="12sp"
                android:textColor="#666" />

            <EditText
                android:id="@+id/editRandom"
                android:layout_width="60dp"
                android:layout_height="36dp"
                android:inputType="number"
                android:text="0"
                android:textSize="13sp"
                android:gravity="center"
                android:background="@drawable/search_bg"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- WiFi/基站开关 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchWifi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WiFi"
                android:textSize="12sp"
                android:checked="true" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchCell"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="基站"
                android:textSize="12sp"
                android:layout_marginStart="16dp"
                android:checked="true" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchGnss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="卫星"
                android:textSize="12sp"
                android:layout_marginStart="16dp"
                android:checked="true" />
        </LinearLayout>

        <!-- 启动/停止按钮 -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_start"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:backgroundTint="#9C27B0" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
